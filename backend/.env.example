# 백엔드 환경변수 예시. 실제 값은 .env에 채워주세요.
# .env는 프로젝트 루트(졸프/) 또는 backend/ 에 두면 됩니다.

# OpenAI / 외부 API
OPENAI_API_KEY=sk-...
GOOGLE_MAPS_API_KEY=AIza...
KTO_API_KEY=...

# Firebase Admin SDK 서비스 계정 키 파일 경로
# - 절대경로 또는 backend/ · 졸프/ 기준 상대경로 모두 허용
# - 파일이 없거나 비어 있어도 앱은 정상 가동되며, 인증만 비활성화됩니다.
FIREBASE_CREDENTIALS_PATH=./firebase-admin.json
